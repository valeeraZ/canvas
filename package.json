{
  "name": "canvas",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "backend:dev": "corepack pnpm --dir apps/backend dev",
    "web:dev": "corepack pnpm --dir apps/web dev",
    "db:up": "docker compose -f infra/local/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/local/docker-compose.yml down",
    "db:push": "DATABASE_URL=postgres://canvas:canvas@localhost:5432/canvas corepack pnpm --dir packages/db db:push",
    "dev:local": "corepack pnpm db:up && corepack pnpm db:push && corepack pnpm --parallel --filter @canvas/backend --filter @canvas/web dev",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
