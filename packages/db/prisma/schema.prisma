generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                String                   @id @default(cuid())
  slug              String                   @unique
  name              String
  memberships       Membership[]
  datasets          Dataset[]
  workbooks         Workbook[]
  dashboards        Dashboard[]
  visibilityRules   DashboardVisibilityRule[]
  appPreferences    PrincipalAppPreference[]
}

model Principal {
  id                   String                 @id @default(cuid())
  externalUserId       String                 @unique
  memberships          Membership[]
  appPreferences       PrincipalAppPreference[]
}

model Membership {
  id          String    @id @default(cuid())
  tenantId    String
  principalId String
  role        String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  principal   Principal @relation(fields: [principalId], references: [id], onDelete: Cascade)

  @@unique([tenantId, principalId])
}

model Dataset {
  id         String      @id @default(cuid())
  tenantId   String
  name       String
  status     String
  warnings   Json?
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  importJobs ImportJob[]
  widgets    DashboardWidget[]
}

model ImportJob {
  id        String   @id @default(cuid())
  datasetId String
  tenantId  String
  status    String
  objectKey String
  warnings  Json?
  dataset   Dataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)
}

model Workbook {
  id       String   @id @default(cuid())
  tenantId String
  name     String
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Dashboard {
  id              String                  @id @default(cuid())
  tenantId        String
  workbookId      String?
  name            String
  tenant          Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  widgets         DashboardWidget[]
  visibilityRules DashboardVisibilityRule[]
  appPreferences  PrincipalAppPreference[]
}

model DashboardWidget {
  id          String     @id @default(cuid())
  tenantId    String
  dashboardId String
  type        String
  datasetId   String?
  config      Json?
  dashboard   Dashboard  @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  dataset     Dataset?   @relation(fields: [datasetId], references: [id], onDelete: SetNull)
}

model DashboardVisibilityRule {
  id          String    @id @default(cuid())
  tenantId    String
  dashboardId String
  subjectType String
  subjectId   String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([tenantId, dashboardId])
}

model PrincipalAppPreference {
  principalId         String
  tenantId            String
  selectedDashboardId String?
  principal           Principal  @relation(fields: [principalId], references: [id], onDelete: Cascade)
  tenant              Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  selectedDashboard   Dashboard? @relation(fields: [selectedDashboardId], references: [id], onDelete: SetNull)

  @@id([principalId, tenantId])
}
